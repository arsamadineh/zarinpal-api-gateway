{
  "name": "@zarinpal/gateway",
  "description": "Production-grade Zarinpal Payment Gateway - Express/Fastify/Hono support with sandbox mode",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.js"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch --onSuccess 'node dist/examples/express-server.js'",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublish": "npm run clean && npm run build"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.4",
    "@vitest/coverage-istanbul": "^3.0.8",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "fastify": "^5.0.1",
    "helmet": "^8.2.0",
    "hono": "^4.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^3.0.8"
  },
  "keywords": [
    "zarinpal",
    "payment-gateway",
    "iran",
    "payment",
    "express",
    "fastify",
    "hono",
    "typescript"
  ],
  "repository": "https://github.com/arsamadineh/zarinpal-api-gateway",
  "author": "Arsam Adineh"
}
