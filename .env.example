# Zarinpal Payment Gateway Configuration
# Copy this file to .env and fill in your credentials

# ============= Core Settings =============
NODE_ENV=development
PORT=3000

# ============= Zarinpal Configuration =============
# Your Zarinpal merchant ID (required)
ZARINPAL_MERCHANT_ID=your-merchant-id-here

# Your Zarinpal API Key (optional)
# ZARINPAL_API_KEY=your-api-key-here

# Use sandbox environment (true = sandbox, false = production)
ZARINPAL_SANDBOX=true

# Request timeout in milliseconds
ZARINPAL_TIMEOUT=30000

# Number of retries for failed requests
ZARINPAL_RETRIES=3

# ============= CORS Configuration =============
# Allowed origin(s) - use '*' for development, specific domain for production
CORS_ORIGIN=*

# ============= Logging =============
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============= Database (Optional) =============
# For storing transactions and payment history
# DATABASE_URL=postgresql://user:password@localhost:5432/zarinpal

# ============= JWT Authentication (Optional) =============
# For securing your API endpoints
# JWT_SECRET=your-super-secret-key-change-this

# ============= Webhook Configuration (Optional) =============
# For async payment notifications
# WEBHOOK_ENABLED=false
# WEBHOOK_SECRET=your-webhook-secret
# WEBHOOK_RETRY_ATTEMPTS=3

# ============= Callback URLs =============
# Default callback URL for payments
# CALLBACK_URL=http://localhost:3000/api/callback

# ============= IP Blocking (Optional) =============
# Comma-separated list of IPs to block
# BLOCKED_IPS=192.168.1.1,10.0.0.1

# ============= Rate Limiting (Optional) =============
# Requests per window
# RATE_LIMIT_MAX=100
# Rate limit window in minutes
# RATE_LIMIT_WINDOW=15

# ============= Email Notifications (Optional) =============
# For payment notification emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# NOTIFICATION_EMAIL=notifications@example.com
